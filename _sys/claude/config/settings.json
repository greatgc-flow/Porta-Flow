{
  "permissions": {
    "allow": [
      "Write(.claude/agents/**)",
      "Write(.claude/skills/**)",
      "Write(_workspace/**)",
      "Write(_archive/**)",
      "Write(_sys/claude/agent/CONTEXT.md)",
      "Bash(_sys/context/*.bat)"
    ],
    "defaultMode": "default"
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "harness@harness-marketplace": true
  },
  "extraKnownMarketplaces": {
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      }
    }
  },
  "effortLevel": "low",
  "theme": "auto",
  "editorMode": "normal",
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
