{
    "permissions": {
        "allow": [
            "Bash(_sys/tools/ripgrep/rg.exe *)",
            "Bash(_sys/tools/fd/fd.exe *)",
            "PowerShell(python _sys/core/hub.py *)",
            "Write(.ai/**)",
            "Write(_sys/**)",
            "Write(.claude/agents/**)",
            "Write(.claude/skills/**)",
            "Write(_archive/**)"
        ]
    },
    "defaultShell": "powershell",
    "env": {
        "CLAUDE_CODE_PACKAGE_MANAGER_AUTO_UPDATE": "false",
        "PYTHONUTF8": "1"
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python \"D:\\PortableDev (v2.0)\\_sys\\checks\\check_contracts.py\" --hook"
                    }
                ]
            }
        ]
    }
}