<Configuration>
  <!-- Porta-Flow Comprehensive Unit Test Sandbox               -->
  <!-- Do NOT launch this template directly.                    -->
  <!-- Use: run-sandbox-test.bat (injects __PORTABLE_ROOT__)    -->
  <!--                                                          -->
  <!-- Layout inside sandbox:                                   -->
  <!--   C:\PortableDev   = host env (read-only)                -->
  <!--   C:\TestResults   = writable, mapped back to host       -->
  <!--   C:\TestWork      = writable workspace (sandbox-local)  -->
  <VGpu>Disable</VGpu>
  <Networking>Default</Networking>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>__PORTABLE_ROOT__</HostFolder>
      <SandboxFolder>C:\PortableDev</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <MappedFolder>
      <HostFolder>__PORTABLE_ROOT__\_archive\test-results</HostFolder>
      <SandboxFolder>C:\TestResults</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>cmd.exe /c "C:\PortableDev\_sys\tests\wsb-entry.bat" &amp; pause</Command>
  </LogonCommand>
</Configuration>
