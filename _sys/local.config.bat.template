@echo off
:: ================================================================
:: local.config.bat  -  Per-PC Configuration
::
:: Created automatically by register.bat.
:: You can add custom overrides below the [/auto] block.
::
:: [auto] block is managed by register.bat - do not edit.
:: User overrides go AFTER the [/auto] block.
:: ================================================================

:: HOW TO USE:
::   1. Copy this file -> rename to "local.config.bat" (same folder)
::   2. Uncomment and edit the settings for this PC
::   3. start.bat loads it automatically on every launch
::
:: This file is PC-specific - do NOT copy to other machines via USB.
:: If using git: add _sys\local.config.bat to .gitignore.

:: -- SUBST (auto-managed by register.bat) --
:: The following lines are written by register.bat.
:: DO NOT edit them manually. Run register.bat to update.
::
:: set "BASE_DIR_PHYS=D:\PortableDev"
:: set "SUBST_DRIVE_LETTER=P"

:: [auto]
:: (register.bat writes SUBST settings here)
:: [/auto]

:: -- Launch behaviour --
:: Prevent Claude Desktop from auto-launching on this PC
:: set "NO_DESKTOP=1"

:: -- Default workspace --
:: Open a different default folder instead of workspace\
:: set "BASE_DIR_WORKSPACE=D:\Projects\MyWork"

:: -- Custom tool paths --
:: Use system-installed npm instead of portable
:: set "NPM_CONFIG_PREFIX=C:\Users\%USERNAME%\AppData\Roaming\npm"

:: -- Gemini settings --
:: Disable Gemini completely on this PC (e.g. offline, no auth)
:: set "NO_GEMINI=1"

:: Enable live auth ping test on every start (costs 1 API call, adds ~2s)
:: Useful if you suspect token expiry. Off by default.
:: set "GEMINI_PING_TEST=1"
