#!/usr/bin/env bash
set -euo pipefail

caller="${BASH_SOURCE[1]:-${BASH_SOURCE[0]}}"
script_dir="$(cd -- "$(dirname -- "$caller")" && pwd -P)"
command_name="$(basename -- "$caller")"
bat_path="$script_dir/$command_name.bat"

if [[ ! -f "$bat_path" ]]; then
  printf 'portable shim error: missing wrapper: %s\n' "$bat_path" >&2
  exit 127
fi

if command -v cygpath >/dev/null 2>&1; then
  bat_path="$(cygpath -w "$bat_path")"
fi

exec cmd.exe //d //q //c call "$bat_path" "$@"
