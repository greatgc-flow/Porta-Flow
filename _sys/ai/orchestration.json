{
  "_comment": "manage.py / hub.py 오케스트레이션 상수. 코드 변경 없이 여기서 조정.",
  "subst": {
    "reserved_letters": ["A", "B", "C"],
    "default_preference_letter": "P"
  },
  "windows": {
    "win11_classic_menu_clsid": "{86ca1aa0-34aa-4e8b-a509-50c905bae2a2}"
  },
  "legacy": {
    "config_file": "local.config.bat"
  },
  "hub_nodes": [
    {
      "node_id": "cc",
      "aliases": ["claude", "anthropic"],
      "type": "peer",
      "invoke": "claude",
      "invoke_args": ["-p", "{query}"],
      "memory": "persistent",
      "timeout": 0
    },
    {
      "node_id": "ca",
      "aliases": ["claude-alt"],
      "type": "peer",
      "invoke": "claude",
      "invoke_args": ["-p", "{query}"],
      "memory": "short-term",
      "timeout": 0
    },
    {
      "node_id": "gc",
      "aliases": ["gemini", "google"],
      "type": "peer",
      "invoke": "gemini",
      "invoke_args": ["-p", "{query}", "-o", "text", "-y"],
      "memory": "session",
      "timeout": 0
    },
    {
      "node_id": "ag",
      "aliases": ["antigravity", "agy"],
      "type": "peer",
      "invoke": "agy",
      "invoke_args": ["--dangerously-skip-permissions", "-p", "{query}"],
      "requires_pty": true,
      "memory": "session",
      "timeout": 0
    },
    {
      "node_id": "cx",
      "aliases": ["codex"],
      "type": "peer",
      "invoke": "codex",
      "invoke_args": ["exec", "{query}", "--json", "--ephemeral", "--ignore-rules"],
      "memory": "session",
      "timeout": 0
    }
  ],
  "consensus": {
    "default_voters": ["cc", "ca", "gc", "ag", "cx"],
    "default_proposer": "cc"
  },
  "check_gate": {
    "default_agent": "gc"
  }
}
