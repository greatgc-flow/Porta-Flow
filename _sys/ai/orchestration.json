{
  "_comment": "manage.py / hub.py 오케스트레이션 상수. 코드 변경 없이 여기서 조정.",
  "subst": {
    "reserved_letters": ["A", "B", "C"],
    "default_preference_letter": "P"
  },
  "windows": {
    "win11_classic_menu_clsid": "{86ca1aa0-34aa-4e8b-a509-50c905bae2a2}"
  },
  "legacy": {
    "config_file": "local.config.bat"
  },
  "hub_nodes": [
    {
      "node_id": "cc",
      "aliases": ["claude", "anthropic"],
      "type": "peer",
      "adapter_class": "ClaudeAdapter",
      "invoke": "claude",
      "invoke_args": ["-p", "{query}", "--allowedTools", "Edit Write Read Glob Grep Bash MultiEdit", "--permission-mode", "acceptEdits"],
      "memory": "persistent",
      "timeout": 0
    },
    {
      "node_id": "ca",
      "enabled": true,
      "aliases": ["claude-alt"],
      "type": "peer",
      "adapter_class": "ClaudeAdapter",
      "invoke": "claude",
      "invoke_args": ["-p", "{query}", "--allowedTools", "Edit Write Read Glob Grep Bash MultiEdit", "--permission-mode", "acceptEdits"],
      "memory": "short-term",
      "timeout": 0
    },
    {
      "node_id": "gc",
      "aliases": ["gemini", "google"],
      "type": "peer",
      "adapter_class": "GeminiAdapter",
      "invoke": "gemini",
      "invoke_args": ["-p", "{query}", "-o", "text", "--approval-mode", "auto_edit", "--skip-trust"],
      "memory": "session",
      "session_mode": "reuse",
      "timeout": 0
    },
    {
      "node_id": "ag",
      "enabled": true,
      "aliases": ["antigravity", "agy"],
      "type": "peer",
      "adapter_class": "AgyAdapter",
      "invoke": "agy",
      "invoke_args": ["--dangerously-skip-permissions", "-p", "{query}"],
      "requires_pty": true,
      "memory": "ephemeral",
      "timeout": 300,
      "_note": "Antigravity CLI (agy v1.0.9) — Gemini Code Assist successor. Activated 2026-06-19 to replace gc. requires_pty=true: Windows console API bypasses subprocess.PIPE."
    },
    {
      "node_id": "cx",
      "aliases": ["codex"],
      "type": "peer",
      "adapter_class": "CodexAdapter",
      "invoke": "codex",
      "invoke_args": ["exec", "{query}", "--json", "--ephemeral", "--ignore-rules", "-s", "danger-full-access"],
      "_note_cx_scope": "full scope: cx needs read access to _sys/ for code-review and cross-checking tasks",
      "memory": "session",
      "session_mode": "reuse",
      "timeout": 0
    },
    {
      "node_id": "cc-deep",
      "aliases": ["claude-deep", "cc.deep"],
      "type": "virtual",
      "adapter_class": "VirtualAdapter",
      "peer": "cc",
      "profile_id": "cc.deep",
      "invoke": "claude",
      "invoke_args": ["-p", "{query}", "--effort", "max", "--allowedTools", "Edit Write Read Glob Grep Bash MultiEdit", "--permission-mode", "acceptEdits"],
      "memory": "persistent",
      "timeout": 0
    },
    {
      "node_id": "gc-plan",
      "aliases": ["gemini-plan", "gc.plan"],
      "type": "virtual",
      "adapter_class": "VirtualAdapter",
      "peer": "gc",
      "profile_id": "gc.plan",
      "invoke": "gemini",
      "invoke_args": ["-p", "{query}", "-o", "text", "--approval-mode", "plan", "--skip-trust"],
      "memory": "session",
      "timeout": 0
    }
  ],
  "consensus": {
    "default_voters": ["cc", "ag", "cx"],
    "inactive_default_voters": ["ca", "gc"],
    "inactive_default_note": "gc: tier_suspended (IneligibleTierError, 2026-06-19). ca: never activated. ag promoted to active voter replacing gc.",
    "default_proposer": "rotating",
    "_proposer_note": "Proposer rotates among active peers (cc → ag → cx → cc). gc replaced by ag as of 2026-06-19."
  },
  "check_gate": {
    "default_agent": "ag"
  },
  "roles_registry": {
    "architect": ["cc", "ag", "cx"],
    "reviewer": ["cc", "ag", "cx"],
    "coder": ["cx", "cc", "ag"],
    "researcher": ["ag", "cc"],
    "_parity_note": "All active peers eligible for all roles. ag replaces gc as of 2026-06-19 (Gemini successor)."
  }
}
