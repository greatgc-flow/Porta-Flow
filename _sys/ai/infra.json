{
    "_version": "1.0",
    "_updated": "2026-06-11",
    "_help": "Physical environment mappings: launcher bat paths, config file registry, tool paths. Read by manage.py, setup.py, and peer entry points. All paths relative to BASE_DIR (P:\\) unless prefixed with _sys/.",

    "base_dirs": {
        "BASE_DIR": "P:\\",
        "SYS_DIR": "_sys",
        "AI_DIR": "_sys/ai",
        "CLI_DIR": "_sys/cli",
        "CORE_DIR": "_sys/core",
        "DOCS_DIR": "_sys/docs-v2",
        "DOCS_ARCHIVE_DIR": "_sys/docs/history",
        "COMMON_DIR": "_sys/ai/common",
        "TOOLS_DIR": "_sys/tools"
    },

    "bat_locations": {
        "_comment": "Launcher bat files for each peer (relative to BASE_DIR)",
        "cc": "_sys/cli/claude.bat",
        "ca": "_sys/cli/claude.bat",
        "gc": "_sys/cli/gemini.bat",
        "ag": "_sys/cli/agy.bat",
        "cx": "_sys/cli/codex.bat",
        "hub": "_sys/cli/hub.bat",
        "collab_rate_gate": "_sys/cli/collab-rate-gate.bat",
        "set_collab_rate": "_sys/cli/set-collab-rate.bat",
        "msg": "_sys/cli/msg.bat"
    },

    "config_registry": {
        "_comment": "Config files for each peer/component (relative to BASE_DIR)",
        "protocol": "_sys/ai/protocol.json",
        "peers": "_sys/ai/peers.json",
        "orchestration": "_sys/ai/orchestration.json",
        "lifecycle_policy": "_sys/ai/lifecycle_policy.json",
        "model_profiles": "_sys/ai/model_profiles.json",
        "model_registry": "_sys/ai/model-registry.json",
        "routing_config": "_sys/ai/routing-config.json",
        "governance_params": "_sys/ai/governance_params.json",
        "logging_config": "_sys/ai/logging-config.json",
        "error_taxonomy": "_sys/ai/error-taxonomy.json",
        "traceability": "_sys/ai/traceability_map.json",
        "infra": "_sys/ai/infra.json",
        "hub_config": "_sys/ai/hub_config.json",
        "env": "_sys/ai/env.json",
        "ssot_docs": "_sys/docs-v2",
        "docs_moc": "_sys/docs-v2/MOC.md",
        "docs_invariants": "_sys/docs-v2/10-invariants.md",
        "cc": {
            "glue": "_sys/claude/config/CLAUDE.md",
            "agents_dir": "_sys/claude/project/agents",
            "skills_dir": "_sys/claude/project/skills",
            "health": "_sys/claude/health.json",
            "statusline": "_sys/claude/config/statusline-command.sh"
        },
        "gc": {
            "glue": "_sys/gemini/config/GEMINI.md",
            "health": "_sys/gemini/health.json",
            "status": "_sys/gemini/status.json",
            "usage": "_sys/gemini/usage.json"
        },
        "ag": {
            "glue": "_sys/antigravity/config/AGY.md",
            "health": "_sys/antigravity/health.json",
            "agentapi_bat": "_sys/antigravity/config/bin/agentapi.bat"
        },
        "cx": {
            "glue": "_sys/codex/config/CODEX.md",
            "health": "_sys/codex/health.json"
        },
        "common": {
            "skills_dir": "_sys/ai/common/skills",
            "agents_dir": "_sys/ai/common/agents",
            "mcp_catalog": "_sys/ai/common/mcp/catalog.json"
        }
    },

    "tool_paths": {
        "_comment": "Native binary paths for each peer (relative to BASE_DIR)",
        "ag": {
            "exe": "_sys/tools/agy/agy.exe",
            "agentapi_args": ["agentapi"],
            "pty_required": true
        },
        "cx": {
            "exe": "codex",
            "invoke_args": ["exec", "-"],
            "default_flags": [
                "--cd", "P:\\",
                "--sandbox", "workspace-write",
                "--ask-for-approval", "never",
                "--json"
            ]
        },
        "gc": {
            "exe": "gemini",
            "config_env": "GEMINI_DIR"
        },
        "cc": {
            "exe": "claude",
            "config_env": "CLAUDE_CONFIG_DIR"
        }
    },

    "ipc_paths": {
        "_comment": "IPC file locations relative to BASE_DIR",
        "ai_root": ".ai",
        "state": ".ai/state.json",
        "handoff": ".ai/handoff.md",
        "mailbox": ".ai/mailbox.json",
        "consensus_dir": ".ai/consensus",
        "out_dir": ".ai/out",
        "query_dir": "_sys/ai/ipc"
    },

    "path_entries": {
        "_comment": "Directories to add to PATH (base relative to SYS_DIR)",
        "cli": "_sys/cli",
        "core": "_sys/core",
        "agy_bin": "_sys/tools/agy"
    }
}
