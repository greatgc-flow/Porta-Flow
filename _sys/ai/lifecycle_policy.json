{
  "_version": "1.0",
  "_help": "Config-driven peer lifecycle, ask failure handling, room reset, and messaging policy. hub.py reads this file; keep behavior rules here instead of hardcoding them.",
  "identity": {
    "node_to_peer": {
      "cc": "claude",
      "ca": "claude",
      "gc": "gemini",
      "ag": "antigravity",
      "cx": "codex"
    },
    "fallback_by_node": {
      "cc": ["cx", "gc"],
      "ca": ["cx", "cc"],
      "gc": ["cc", "cx"],
      "ag": ["cc", "cx"],
      "cx": ["cc", "gc"]
    }
  },
  "ask_failure_classification": {
    "default_reason": "nonzero_exit",
    "nonzero_exit_mode": "warn_preserve_output",
    "patterns": [
      {
        "reason": "sandbox_spawn_eperm",
        "category": "ENVIRONMENT",
        "match_any": ["spawn eperm", "eperm"],
        "availability": {"sandbox_blocked": true},
        "health_action": "RED_GATE_CLOSED"
      },
      {
        "reason": "rate_or_session_limit",
        "category": "RESOURCE",
        "match_any": ["session limit", "rate limit", "quota"],
        "availability": {"rate_limit_state": "limited"},
        "capture_retry_hint_when_contains": "resets",
        "health_action": "RED_GATE_CLOSED"
      },
      {
        "reason": "workspace_not_trusted",
        "category": "ENVIRONMENT",
        "match_any": ["not running in a trusted directory", "trust_workspace"],
        "availability": {"workspace_not_trusted": true},
        "health_action": "YELLOW_WARN"
      },
      {
        "reason": "timeout",
        "category": "TRANSIENT",
        "match_any": ["timed out", "timeout"],
        "health_action": "COUNT_FAILURE"
      },
      {
        "reason": "cli_not_found",
        "category": "ENVIRONMENT",
        "match_any": ["not found"],
        "health_action": "RED_GATE_CLOSED"
      }
    ]
  },
  "health_lifecycle": {
    "failure_warn": 3,
    "failure_error": 5,
    "monitoring": {
      "zero_token_default": true,
      "check_at": [
        "peer_entry_start",
        "before_delegation",
        "before_peer_ask",
        "session_boundary",
        "peer_exit"
      ],
      "stale_source": "leader_election.health_stale_minutes",
      "stale_action": "mark_stale_and_append_handoff_issue",
      "routine_commands": [
        "health-check",
        "peer-status",
        "health-precheck",
        "health-sweep"
      ]
    },
    "recovery": {
      "YELLOW": "success_resets_failures_or_failure_error_promotes_red",
      "STALE": "avoid_assignment_then_refresh_or_failover",
      "RED": "quarantine_repair_diagnostic_peer_recover",
      "manual_green_update_is_not_red_recovery": true
    },
    "critical_reasons": [
      "sandbox_spawn_eperm",
      "rate_or_session_limit",
      "cli_not_found"
    ],
    "transient_red_recovery_reasons": [
      "sandbox_spawn_eperm",
      "rate_or_session_limit",
      "cli_not_found"
    ],
    "state_actions": {
      "GREEN": {
        "primary_usage": "allow",
        "fallback_usage": "allow"
      },
      "YELLOW": {
        "primary_usage": "avoid_new_directives",
        "fallback_usage": "allow",
        "on_enter": ["checkpoint_at_next_pause"]
      },
      "RED": {
        "primary_usage": "block",
        "fallback_usage": "block",
        "on_enter": ["checkpoint_handoff", "quarantine_peer"],
        "recover_by": "diagnostic_success_or_manual_clear"
      }
    }
  },
  "room_lifecycle": {
    "topic_change_strategy": "new_room",
    "new_topic": {
      "archive_current_handoff": true,
      "end_all_members": true,
      "create_new_room": true,
      "carry_sections": ["KEY_DECISIONS"],
      "clear_sections": ["GOAL", "RECENT_COMPLETED", "PENDING_ISSUES", "CONSENSUS_HISTORY", "ACTIVE_THREADS"]
    },
    "clear_room": {
      "requires_human_initiation": true,
      "archive_mailbox": true,
      "mark_unread_as_stale": true,
      "end_all_members": true,
      "create_new_room": true
    },
    "all_peers_red_action": "ESCALATE_TIER_0"
  },
  "messaging": {
    "broadcast": {
      "mode": "enabled",
      "role": "fanout_mailbox_notice",
      "default_targets": "room_members_except_sender",
      "large_payload_strategy": "single_payload_reference_per_recipient",
      "do_not_use_for": ["blocking_decision", "private_peer_review"]
    },
    "send": {
      "mode": "retain_improve",
      "role": "async_mailbox_only",
      "default_priority": "INFO",
      "allowed_types": ["MSG", "DIRECTIVE", "ARTIFACT", "VERIFY", "PAYLOAD_REF", "APPROVAL_REQUEST"],
      "ttl_hours_by_priority": {
        "CRITICAL": 24,
        "DIRECTIVE": 12,
        "INFO": 4
      },
      "process_on_startup": true,
      "do_not_use_for": ["consensus_vote", "synchronous_review", "blocking_decision"],
      "migration_target": "durable_maildir_transport"
    }
  }
}
