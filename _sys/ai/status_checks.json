{
  "_version": "1.0",
  "_updated": "2026-06-20",
  "_purpose": "Zero-token probe definitions. Lifecycle and gate state come from orchestration.json plus live health, never peer-specific gate files.",
  "general_contract": {
    "authoritative_lifecycle": "orchestration.json",
    "authoritative_runtime_health": "_sys/{installation}/health.json",
    "freshness_source": "health timestamp and ask history",
    "model_calls_for_routine_status": false,
    "secret_policy": "never_record_secret_values"
  },
  "peers": {
    "cc": {
      "safe_checks": [
        {"id": "cc.version", "class": "version_only", "command": "claude --version", "effect_class": "read_only"},
        {"id": "cc.auth", "class": "local_config_presence", "command": "claude auth status", "effect_class": "read_only", "redact": ["email", "orgId", "orgName"]},
        {"id": "cc.models", "class": "account_model_smoke_test", "command": "profile-specific claude --model invocation", "effect_class": "model_call", "frequency": "on_profile_change", "notes": "Claude Code has no zero-token model-list subcommand. Profile availability is verified by a minimal JSON invocation."}
      ],
      "known_overrides": {
        "model_flag": "--model",
        "effort_flag": "--effort",
        "permission_mode_flag": "--permission-mode"
      }
    },
    "ca": {
      "inherits": "cc"
    },
    "gc": {
      "safe_checks": [
        {"id": "gc.version", "class": "version_only", "command": "gemini --version", "effect_class": "read_only"}
      ],
      "known_overrides": {
        "model_flag": "--model",
        "approval_mode_flag": "--approval-mode"
      }
    },
    "ag": {
      "safe_checks": [
        {"id": "ag.version", "class": "version_only", "command": "agy --version", "effect_class": "read_only"},
        {"id": "ag.models", "class": "local_model_listing", "command": "agy models", "effect_class": "read_only", "requires_pty": true, "notes": "Model listing is rendered through the Windows Console API and must be captured with a PTY."}
      ],
      "known_overrides": {
        "model_flag": "--model"
      }
    },
    "cx": {
      "safe_checks": [
        {"id": "cx.version", "class": "version_only", "command": "codex --version", "effect_class": "read_only"},
        {"id": "cx.models", "class": "local_model_listing", "command": "codex debug models", "effect_class": "read_only", "notes": "Returns the current account/runtime model catalog and supported reasoning levels as JSON."},
        {"id": "cx.doctor", "class": "low_quota_diagnostic", "command": "codex doctor", "effect_class": "external_io", "frequency": "manual"}
      ],
      "known_overrides": {
        "model_flag": "--model",
        "reasoning_effort_flag": "-c model_reasoning_effort"
      }
    }
  }
}
