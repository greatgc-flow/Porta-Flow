{
  "_version": "2.0",
  "_help": "Installation/provider registry only. Logical peers, lifecycle, profiles, permissions, and roles live in orchestration.json.",
  "peers": {
    "claude": {
      "enabled": true,
      "description": "Anthropic Claude Code CLI",
      "gate": null,
      "npm_package": "@anthropic-ai/claude-code",
      "root_dir": ".claude",
      "sys_subdir": "claude",
      "host_junction": {
        "host_env": "USERPROFILE",
        "host_dirname": ".claude",
        "portable_subpath": "config"
      },
      "project_junction": {
        "portable_subpath": "project"
      },
      "workspace": {
        "shadow_subdir": ".ai/claude",
        "junction_name": ".claude",
        "glue_file": "CLAUDE.md",
        "glue_template": "templates/workspace.md"
      },
      "env_vars": {
        "CLAUDE_CONFIG_DIR": "config"
      },
      "local_settings": [
        {
          "target": "project/settings.local.json",
          "content": {
            "permissions": {
              "allow": [
                "Bash(cmd /c \"{DRIVE}:\\_sys\\cli\\msg.bat\" *)",
                "PowerShell(cmd /c \"{DRIVE}:\\_sys\\cli\\msg.bat\" *)",
                "PowerShell(cmd /c \"{DRIVE}:\\_sys\\cli\\msg.bat\" ask *)",
                "PowerShell(cmd /c \"{DRIVE}:\\_sys\\cli\\claude.bat\" *)",
                "PowerShell(cmd /c \"{DRIVE}:\\_sys\\cli\\gemini.bat\" *)",
                "PowerShell(cmd /c \"{DRIVE}:\\_sys\\cli\\codex.bat\" *)",
                "PowerShell(cmd /c \"{DRIVE}:\\_sys\\cli\\agy.bat\" *)",
                "PowerShell(Get-ChildItem \"{DRIVE}:\\_sys\\ *)",
                "PowerShell(Get-Content \"{DRIVE}:\\ *)"
              ]
            }
          }
        }
      ],
      "host_app": {
        "env_base": "LOCALAPPDATA",
        "rel_path": "Programs/Claude/Claude.exe",
        "launch_on_start": true
      },
      "cleanup": {
        "peer_paths": [],
        "peer_globs": [],
        "config_paths": [
          "daemon.log",
          "plugins/cache/"
        ]
      },
      "relocate": {
        "patch": [
          "project/settings.local.json",
          "config/daemon/roster.json",
          "config/plugins/known_marketplaces.json"
        ],
        "delete": [
          "config/daemon.lock",
          "config/.claude.json"
        ]
      },
      "node_ids": [
        "cc",
        "ca"
      ]
    },
    "gemini": {
      "enabled": false,
      "description": "Google Gemini CLI",
      "gate": null,
      "npm_package": "@google/gemini-cli",
      "root_dir": ".gemini",
      "sys_subdir": "gemini",
      "host_junction": {
        "host_env": "USERPROFILE",
        "host_dirname": ".gemini",
        "portable_subpath": "config"
      },
      "project_junction": {
        "portable_subpath": "project"
      },
      "workspace": {
        "shadow_subdir": ".ai/gemini",
        "junction_name": ".gemini",
        "glue_file": "GEMINI.md",
        "glue_template": "templates/workspace.md"
      },
      "env_vars": {
        "GEMINI_CLI_TRUST_WORKSPACE": true
      },
      "local_settings": [],
      "host_app": null,
      "cleanup": {
        "peer_paths": [
          "usage.json",
          "session-map.json",
          "session.lock",
          "session-id.txt"
        ],
        "peer_globs": [
          "cq-*.txt"
        ],
        "config_paths": [
          "tmp/"
        ]
      },
      "node_ids": [
        "gc"
      ]
    },
    "codex": {
      "enabled": true,
      "description": "OpenAI Codex CLI",
      "gate": null,
      "npm_package": "@openai/codex",
      "root_dir": ".codex",
      "sys_subdir": "codex",
      "host_junction": null,
      "project_junction": null,
      "workspace": {
        "shadow_subdir": ".ai/codex",
        "junction_name": ".codex",
        "glue_file": "CODEX.md",
        "glue_template": "templates/workspace.md"
      },
      "env_vars": {},
      "local_settings": [],
      "host_app": null,
      "cleanup": {
        "peer_paths": [],
        "peer_globs": [],
        "config_paths": []
      },
      "node_ids": [
        "cx"
      ]
    },
    "antigravity": {
      "enabled": true,
      "description": "Google Antigravity CLI (agy) — Gemini CLI successor",
      "gate": null,
      "npm_package": null,
      "native_binary": {
        "bin_name": "agy",
        "win_exe": "agy.exe",
        "install_subdir": "tools/agy"
      },
      "root_dir": ".agy",
      "sys_subdir": "antigravity",
      "host_junction": {
        "host_env": "USERPROFILE",
        "host_dirname": ".gemini\\antigravity-cli",
        "portable_subpath": "config"
      },
      "project_junction": {
        "portable_subpath": "project"
      },
      "workspace": {
        "shadow_subdir": ".ai/antigravity",
        "junction_name": ".agy",
        "glue_file": "AGY.md",
        "glue_template": "templates/workspace.md"
      },
      "env_vars": {
        "AGY_CONFIG_HOME": "config",
        "GEMINI_DIR": "config"
      },
      "ipc_stateless_home": {
        "description": "A6: agy auto-continues durable session state (conversations/*.db + implicit/*.pb) even without -c, contaminating IPC asks with prior interactive context. For hub.py IPC invocations only, repoint the config home to a dedicated dir that mirrors auth/model settings but whose durable-state dirs are emptied before every call, so each ag ask is stateless. The interactive `config/` home is never modified.",
        "subdir": "ipc-config",
        "seed_from": "config",
        "seed_files": ["settings.json", "installation_id", "AGY.md", "keybindings.json", "status.json", "usage.json"],
        "ephemeral_dirs": ["conversations", "implicit"],
        "env_keys": ["AGY_CONFIG_HOME", "GEMINI_DIR"]
      },
      "local_settings": [],
      "host_app": null,
      "cleanup": {
        "peer_paths": [],
        "peer_globs": [],
        "config_paths": []
      },
      "node_ids": [
        "ag"
      ]
    }
  }
}
