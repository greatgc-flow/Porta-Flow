{
  "schema_version": 1,
  "description": "Unified statusline field schema. All peers SHOULD display these fields in this order.",
  "fields": [
    {
      "id": "peer_model",
      "label": "Peer & Model",
      "format": "{peer_id}:{model_name}",
      "required": true,
      "example": "cc:opus"
    },
    {
      "id": "context",
      "label": "Context Usage",
      "format": "ctx:{used_k}k/{total_k}k ({pct}%)",
      "required": true,
      "example": "ctx:42k/200k (21%)"
    },
    {
      "id": "location",
      "label": "Directory & Branch",
      "format": "{basename} ({git_branch})",
      "required": true,
      "example": "Engram (main)"
    },
    {
      "id": "rate_limits",
      "label": "Rate Limits",
      "format": "5h:{five_pct}% 7d:{week_pct}%",
      "required": true,
      "fallback": "5h:N/A 7d:N/A",
      "example": "5h:15% 7d:8%"
    },
    {
      "id": "hub_status",
      "label": "Hub Session",
      "format": "hub:{status}",
      "required": false,
      "example": "hub:active"
    }
  ],
  "separator": " | ",
  "peer_mapping": {
    "cc": {
      "mechanism": "command_script",
      "model_path": ".model.display_name",
      "ctx_used_path": ".context_window.total_input_tokens",
      "ctx_total_path": ".context_window.context_window_size",
      "ctx_pct_path": ".context_window.used_percentage",
      "cwd_path": ".workspace.current_dir // .cwd",
      "rate_5h_path": ".rate_limits.five_hour.used_percentage",
      "rate_7d_path": ".rate_limits.seven_day.used_percentage",
      "rate_5h_reset_path": ".rate_limits.five_hour.reset_at"
    },
    "ag": {
      "mechanism": "command_script",
      "model_path": ".model",
      "cwd_path": ".cwd",
      "note": "Rate limit and context data supplemented from health.json"
    },
    "cx": {
      "mechanism": "builtin_enum",
      "fields": [
        "model-with-reasoning",
        "current-dir",
        "context-remaining",
        "context-window-size",
        "used-tokens",
        "five-hour-limit",
        "weekly-limit",
        "run-state",
        "task-progress"
      ],
      "note": "Codex uses internal field identifiers; custom script not supported"
    }
  }
}
