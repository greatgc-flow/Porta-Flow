{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portable-dev.local/schemas/collaboration-policy.schema.json",
  "title": "Collaboration Policy",
  "type": "object",
  "required": [
    "schema_version",
    "policy_version",
    "policy_scope",
    "owner",
    "authority_levels",
    "invariants",
    "precedence",
    "lifecycle",
    "zero_token_boundary",
    "connector_declaration",
    "connectors",
    "ambiguity_contract",
    "observability",
    "failure_modes",
    "security_privacy"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    },
    "policy_scope": {
      "type": "string",
      "enum": ["default", "general", "project", "room", "peer", "task"]
    },
    "owner": {
      "type": "string"
    },
    "extends": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compatibility": {
      "type": "object",
      "required": ["min_schema_version"],
      "properties": {
        "min_schema_version": {
          "type": "string"
        },
        "migration_note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "authority_levels": {
      "type": "object",
      "required": ["peer_equality", "human_veto"],
      "properties": {
        "peer_equality": {
          "type": "string",
          "const": "equal_within_granted_authority"
        },
        "human_veto": {
          "type": "boolean"
        },
        "roles": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["read_only", "review", "propose", "execute_local", "admin"]
          }
        }
      },
      "additionalProperties": false
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "authority", "override_policy", "rule"],
        "properties": {
          "name": {
            "type": "string"
          },
          "authority": {
            "type": "string",
            "enum": ["general", "human", "security", "repository"]
          },
          "override_policy": {
            "type": "string",
            "enum": ["locked", "narrow_only"]
          },
          "rule": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "precedence": {
      "type": "array",
      "prefixItems": [
        { "const": "default" },
        { "const": "general" },
        { "const": "project" },
        { "const": "room" },
        { "const": "peer" },
        { "const": "task" }
      ],
      "minItems": 6,
      "maxItems": 6
    },
    "lifecycle": {
      "type": "array",
      "prefixItems": [
        { "const": "observe" },
        { "const": "classify" },
        { "const": "decide" },
        { "const": "sync" },
        { "const": "act_or_ask" },
        { "const": "record" },
        { "const": "handoff" },
        { "const": "improve" }
      ],
      "minItems": 8,
      "maxItems": 8
    },
    "zero_token_boundary": {
      "type": "object",
      "required": ["allowed_ops", "forbidden_ops", "state_sources"],
      "properties": {
        "allowed_ops": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["read", "merge", "validate", "classify"]
          },
          "uniqueItems": true
        },
        "forbidden_ops": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "state_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "connector_declaration": {
      "type": "object",
      "required": [
        "dry_declaration_authority",
        "runtime_assertion_rejected",
        "dry_requires",
        "effect_classes"
      ],
      "properties": {
        "dry_declaration_authority": {
          "type": "string",
          "const": "schema_validated_connector_metadata"
        },
        "runtime_assertion_rejected": {
          "type": "boolean",
          "const": true
        },
        "dry_requires": {
          "type": "object",
          "required": ["effect_class", "idempotent", "external_io", "workspace_writes"],
          "properties": {
            "effect_class": {
              "type": "string",
              "enum": ["read_only", "declared_dry_validate"]
            },
            "idempotent": {
              "type": "boolean",
              "const": true
            },
            "external_io": {
              "type": "string",
              "const": "none"
            },
            "workspace_writes": {
              "type": "boolean",
              "const": false
            }
          },
          "additionalProperties": false
        },
        "effect_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "none",
              "read_only",
              "declared_dry_validate",
              "local_temp_write",
              "peer_state",
              "governance_write",
              "workspace_write",
              "process_mutation",
              "external_io"
            ]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "connectors": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "intent",
          "candidates",
          "filters",
          "selection",
          "record",
          "side_effect",
          "operation_class",
          "effect_class",
          "action_policy",
          "idempotent",
          "external_io",
          "cache_policy",
          "requires_lock",
          "idempotency",
          "path_safety",
          "exit_code_mapping"
        ],
        "properties": {
          "intent": {
            "type": "string"
          },
          "candidates": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "filters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "selection": {
            "type": "string"
          },
          "record": {
            "type": "object",
            "required": ["event", "actor", "timestamp", "policy_version", "inputs_ref", "outputs_ref"],
            "properties": {
              "event": { "type": "string" },
              "actor": { "type": "string" },
              "timestamp": { "type": "string" },
              "policy_version": { "type": "string" },
              "decision_ref": { "type": "string" },
              "inputs_ref": { "type": "string" },
              "outputs_ref": { "type": "string" }
            },
            "additionalProperties": false
          },
          "side_effect": {
            "type": "string",
            "enum": ["none", "read", "write", "execute"]
          },
          "operation_class": {
            "type": "string",
            "enum": ["observe", "validate", "classify", "ask", "decide", "implement", "record"]
          },
          "effect_class": {
            "type": "string",
            "enum": [
              "none",
              "read_only",
              "declared_dry_validate",
              "local_temp_write",
              "peer_state",
              "governance_write",
              "workspace_write",
              "process_mutation",
              "external_io"
            ]
          },
          "action_policy": {
            "type": "string",
            "enum": [
              "exempt",
              "requires_classification",
              "pre_consensus_allowed",
              "requires_finalized_consensus",
              "human_override_required"
            ]
          },
          "idempotent": {
            "type": "boolean"
          },
          "external_io": {
            "type": "string",
            "enum": ["none", "local_only", "network", "unknown"]
          },
          "cache_policy": {
            "type": "string",
            "enum": ["none", "local_temp_only", "writes_logs", "unknown"]
          },
          "requires_lock": {
            "type": "boolean"
          },
          "lock_target": {
            "type": "string"
          },
          "idempotency": {
            "type": "object",
            "required": ["mode"],
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["idempotent", "idempotency_key", "non_idempotent"]
              },
              "key_template": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "path_safety": {
            "type": "object",
            "required": ["portable_only", "allow_absolute_paths", "allow_unc_paths"],
            "properties": {
              "portable_only": { "type": "boolean" },
              "allow_absolute_paths": { "type": "boolean" },
              "allow_unc_paths": { "type": "boolean" }
            },
            "additionalProperties": false
          },
          "exit_code_mapping": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "action_policy": { "const": "exempt" }
              },
              "required": ["action_policy"]
            },
            "then": {
              "properties": {
                "effect_class": {
                  "enum": ["read_only", "declared_dry_validate"]
                },
                "idempotent": { "const": true },
                "external_io": { "enum": ["none", "local_only"] },
                "side_effect": { "enum": ["none", "read"] }
              }
            }
          },
          {
            "if": {
              "properties": {
                "side_effect": { "enum": ["write", "execute"] }
              },
              "required": ["side_effect"]
            },
            "then": {
              "required": ["lock_target"]
            }
          },
          {
            "if": {
              "properties": {
                "requires_lock": { "const": true }
              },
              "required": ["requires_lock"]
            },
            "then": {
              "required": ["lock_target"]
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "ambiguity_contract": {
      "type": "object",
      "required": ["entries"],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "status",
              "uncertainty",
              "candidates",
              "confidence",
              "ask_threshold",
              "escalation",
              "actor",
              "detected_at"
            ],
            "properties": {
              "id": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["pending", "asking", "escalated", "resolved", "ignored"]
              },
              "uncertainty": { "type": "string" },
              "candidates": {
                "type": "array",
                "items": { "type": "string" }
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "ask_threshold": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "escalation": {
                "type": "string",
                "enum": ["ask_peer", "consensus", "human", "halt"]
              },
              "actor": { "type": "string" },
              "detected_at": { "type": "string" },
              "resolution_ref": { "type": "string" }
            },
            "additionalProperties": false,
            "allOf": [
              {
                "if": {
                  "properties": {
                    "status": { "const": "resolved" }
                  },
                  "required": ["status"]
                },
                "then": {
                  "required": ["resolution_ref"]
                }
              }
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "observability": {
      "type": "object",
      "required": ["events", "provenance_required"],
      "properties": {
        "events": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["observe", "classify", "decide", "sync", "act", "ask", "record", "handoff", "improve"]
          }
        },
        "provenance_required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "failure_modes": {
      "type": "object",
      "required": ["default", "unknown_classification", "schema_mismatch", "stale_policy", "lock_failure"],
      "properties": {
        "default": { "type": "string", "const": "fail_closed" },
        "unknown_classification": { "type": "string" },
        "schema_mismatch": { "type": "string" },
        "stale_policy": { "type": "string" },
        "lock_failure": { "type": "string" }
      },
      "additionalProperties": false
    },
    "security_privacy": {
      "type": "object",
      "required": ["redact_secrets", "allowed_storage", "forbidden_logging"],
      "properties": {
        "redact_secrets": { "type": "boolean" },
        "allowed_storage": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_logging": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "patternProperties": {
    "^x-": true
  },
  "additionalProperties": false
}
