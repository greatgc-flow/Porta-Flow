{
  "schema_version": "1.0.0",
  "policy_version": "1.0.0-example",
  "policy_scope": "room",
  "owner": "example-room",
  "extends": [
    "_sys/ai/protocol.json",
    "_sys/ai/lifecycle_policy.json"
  ],
  "compatibility": {
    "min_schema_version": "1.0.0",
    "migration_note": "Example policy for room-scoped overrides."
  },
  "authority_levels": {
    "peer_equality": "equal_within_granted_authority",
    "human_veto": true,
    "roles": {
      "human": "admin",
      "cc": "propose",
      "gc": "propose",
      "ag": "propose",
      "cx": "propose"
    }
  },
  "invariants": [
    {
      "name": "preserve_user_intent",
      "authority": "general",
      "override_policy": "locked",
      "rule": "User intent must remain visible in room state and handoff."
    },
    {
      "name": "workspace_write_consensus",
      "authority": "repository",
      "override_policy": "narrow_only",
      "rule": "Workspace-changing policy edits require consensus or human authority."
    },
    {
      "name": "secret_redaction",
      "authority": "security",
      "override_policy": "locked",
      "rule": "Secrets and credentials must not be logged, broadcast, or copied into handoff."
    }
  ],
  "precedence": [
    "default",
    "general",
    "project",
    "room",
    "peer",
    "task"
  ],
  "lifecycle": [
    "observe",
    "classify",
    "decide",
    "sync",
    "act_or_ask",
    "record",
    "handoff",
    "improve"
  ],
  "zero_token_boundary": {
    "allowed_ops": [
      "read",
      "merge",
      "validate",
      "classify"
    ],
    "forbidden_ops": [
      "external_model_call",
      "undeclared_rule_creation",
      "semantic_inference_without_policy"
    ],
    "state_sources": [
      ".ai/state.json",
      ".ai/mailbox.json",
      ".ai/sessions/{ROOM_ID}/handoff.md",
      "_sys/ai/*.json",
      "_sys/*/health.json"
    ]
  },
  "connector_declaration": {
    "dry_declaration_authority": "schema_validated_connector_metadata",
    "runtime_assertion_rejected": true,
    "dry_requires": {
      "effect_class": "declared_dry_validate",
      "idempotent": true,
      "external_io": "none",
      "workspace_writes": false
    },
    "effect_classes": [
      "none",
      "read_only",
      "declared_dry_validate",
      "local_temp_write",
      "peer_state",
      "governance_write",
      "workspace_write",
      "process_mutation",
      "external_io"
    ]
  },
  "connectors": {
    "verify_health": {
      "intent": "verify_health",
      "candidates": [
        "_sys/cli/msg.bat health-check",
        "_sys/checks/check-health.bat"
      ],
      "filters": [
        "portable_path_only",
        "read_or_validate_only"
      ],
      "selection": "prefer_existing_hub_cli",
      "record": {
        "event": "classify",
        "actor": "{PEER_ID}",
        "timestamp": "{ISO8601}",
        "policy_version": "{POLICY_VERSION}",
        "decision_ref": "{DECISION_REF}",
        "inputs_ref": "{HEALTH_FILES_REF}",
        "outputs_ref": "{EVENT_LOG_REF}"
      },
      "side_effect": "read",
      "operation_class": "validate",
      "effect_class": "declared_dry_validate",
      "action_policy": "exempt",
      "idempotent": true,
      "external_io": "none",
      "cache_policy": "none",
      "requires_lock": false,
      "idempotency": {
        "mode": "idempotent"
      },
      "path_safety": {
        "portable_only": true,
        "allow_absolute_paths": false,
        "allow_unc_paths": false
      },
      "exit_code_mapping": {
        "0": "ok",
        "1": "warning",
        "2": "blocked"
      }
    },
    "checkpoint_handoff": {
      "intent": "checkpoint_handoff",
      "candidates": [
        "_sys/cli/msg.bat checkpoint --agent {PEER_ID} --msg {MESSAGE_REF}"
      ],
      "filters": [
        "portable_path_only",
        "requires_handoff_lock"
      ],
      "selection": "single_declared_connector",
      "record": {
        "event": "handoff",
        "actor": "{PEER_ID}",
        "timestamp": "{ISO8601}",
        "policy_version": "{POLICY_VERSION}",
        "decision_ref": "{DECISION_REF}",
        "inputs_ref": "{MESSAGE_REF}",
        "outputs_ref": "{HANDOFF_REF}"
      },
      "side_effect": "write",
      "operation_class": "record",
      "effect_class": "governance_write",
      "action_policy": "requires_finalized_consensus",
      "idempotent": true,
      "external_io": "none",
      "cache_policy": "writes_logs",
      "requires_lock": true,
      "lock_target": "handoff",
      "idempotency": {
        "mode": "idempotency_key",
        "key_template": "{ROOM_ID}:{PEER_ID}:{MESSAGE_HASH}"
      },
      "path_safety": {
        "portable_only": true,
        "allow_absolute_paths": false,
        "allow_unc_paths": false
      },
      "exit_code_mapping": {
        "0": "recorded",
        "1": "failed"
      }
    }
  },
  "ambiguity_contract": {
    "entries": [
      {
        "id": "amb-example-001",
        "status": "pending",
        "uncertainty": "Two healthy peers match the same verification intent with equal policy score.",
        "candidates": [
          "choose_lowest_recent_failure_rate",
          "ask_peer",
          "escalate_to_human"
        ],
        "confidence": 0.55,
        "ask_threshold": 0.7,
        "escalation": "consensus",
        "actor": "{PEER_ID}",
        "detected_at": "{ISO8601}"
      }
    ]
  },
  "observability": {
    "events": [
      "observe",
      "classify",
      "decide",
      "sync",
      "act",
      "ask",
      "record",
      "handoff",
      "improve"
    ],
    "provenance_required": true
  },
  "failure_modes": {
    "default": "fail_closed",
    "unknown_classification": "ask_or_escalate",
    "schema_mismatch": "block_policy_use",
    "stale_policy": "refresh_or_escalate",
    "lock_failure": "retry_then_escalate"
  },
  "security_privacy": {
    "redact_secrets": true,
    "allowed_storage": [
      ".ai/",
      "_sys/ai/",
      "_sys/data/temp/"
    ],
    "forbidden_logging": [
      "credentials",
      "tokens",
      "private_keys",
      "full_secret_values"
    ]
  },
  "x-example-note": {
    "purpose": "Demonstrates a room-scoped Specific policy without binding the protocol to a real room or model."
  }
}
