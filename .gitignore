_sys/codex/config/plugins/
_sys/codex/config/skills/
_sys/codex/config/version.json

# =================================================================
# 6. Test Environments & Results
# =================================================================
_sys/tests/results/
_sys/tests/local_test_tmp/
_sys/tests/integration/parallel_test_tmp/
_sys/tests/integration/recovery_test_tmp/
_sys/tests/integration/local_test_tmp/
.pytest_cache/
setup_test_env.py
_sys/temp_manual_gen.py

# =================================================================
# 7. Root-level session/debug log dumps
# =================================================================
/agy_log*.txt
/out.txt
/err.txt
/integration_log.txt
/integration_log*.txt
# Accidental 0-byte peer temp files (e.g., /See created by cx during ask session)
/See
/Remains
# Python temporary-directory write probes contain exactly "blat". These files
# are detected by validation and should be removed, not silently ignored.

# Pytest temp dirs scattered to root
/.pytest-basetemp/
/.pytest-local/
/.pytest-tmp/
/.pytest-work/
/pytest_local/

# =================================================================
# 8. System, Editor, & Cache Garbage
# =================================================================
# Personal brain-dump / credential notes — never commit
/MemoryDump.md
/Garbage/
/tmp/
.DS_Store
Thumbs.db
.vscode/
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
*.log
*.tmp
*.bak

# Test sandbox run-logs (E2 — were tracked + dirtied every test run)
_sys/tests/_sys/data/logs/*.jsonl
