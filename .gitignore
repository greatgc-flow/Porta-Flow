# Porta-Flow: Minimal Core Git Ignore (MECE)

# =================================================================
# 1. User Workspaces, Data, and Archives
# =================================================================
/workspace/
/_workspace/
/_archive/
WORKLOG.md

# =================================================================
# 2. Ephemeral State & IPC (Inter-Process Communication)
# =================================================================
.ai/
_state/

# =================================================================
# 3. Downloaded Environments, Binaries, and Runtimes
# =================================================================
# env/ is bootstrapped via install.bat — not tracked
_sys/env/
# tools/apps/ is user-installed on first run — not tracked
_sys/tools/apps/
# tools/agy/ — native binary (150MB+), bootstrapped via setup.py
_sys/tools/agy/
_sys/data/temp/
_sys/data/setup-files/
_sys/data/logs/

# =================================================================
# 4. Local Configurations & Device-Specific State
# =================================================================
# Do not track drive letters, context menu states, or local overrides
**/local.config.bat
_sys/config.json
_sys/core/config.json
_sys/data/last_base_dir.txt
.env

# =================================================================
# 5. Agent Dynamic Data & Status Logs (Peer-Agnostic)
# =================================================================
# Root AI peer junction dirs (junctions → _sys/{peer}/project/)
# Adding a new peer: add its root_dir here (see _sys/ai/peers.json)
.claude/
.gemini/
.chatgpt/

# Per-peer runtime state (peer-agnostic wildcard)
_sys/*/project/settings.local.json
_sys/*/status.json
_sys/*/usage.json
_sys/*/session-id.txt
_sys/*/session-map.json
_sys/*/session.lock
_sys/*/cq-*.txt

# Claude auth/runtime data in config/ (tracked: CLAUDE.md, settings.json, statusline-command.sh)
_sys/claude/config/.claude.json
_sys/claude/config/.credentials.json
_sys/claude/config/.last-cleanup
_sys/claude/config/.last-update-result.json
_sys/claude/config/backups/
_sys/claude/config/cache/
_sys/claude/config/daemon.lock
_sys/claude/config/daemon.status.json
_sys/claude/config/daemon/
_sys/claude/config/file-history/
_sys/claude/config/history.jsonl
_sys/claude/config/jobs/
_sys/claude/config/paste-cache/
_sys/claude/config/plans/
_sys/claude/config/plugins/
_sys/claude/config/projects/
_sys/claude/config/sessions/
_sys/claude/config/shell-snapshots/
_sys/claude/config/stats-cache.json
_sys/claude/config/tasks/
_sys/claude/config/tmp/

# Antigravity (agy) runtime data — tracked: bin/agentapi.bat, health.json
# Everything else in config/ is runtime-generated
_sys/antigravity/config/brain/
_sys/antigravity/config/conversations/
_sys/antigravity/config/cache/
_sys/antigravity/config/log/
_sys/antigravity/config/implicit/
_sys/antigravity/config/updater/
_sys/antigravity/config/builtin/
_sys/antigravity/config/knowledge/
_sys/antigravity/config/*.log
_sys/antigravity/config/*.jsonl
_sys/antigravity/config/*.json
_sys/antigravity/config/*.timestamp
_sys/antigravity/config/installation_id
_sys/antigravity/config/*.exe
_sys/antigravity/config/bin/*.exe
# Re-include tracked files
!_sys/antigravity/config/bin/agentapi.bat

# Codex runtime data in config/ (tracked: CODEX.md)
_sys/codex/config/.codex/
_sys/codex/config/history/
_sys/codex/config/sessions/

# Gemini auth/runtime data in config/ (tracked: GEMINI.md, CONTEXT.md, policies/)
_sys/gemini/config/google_accounts.json
_sys/gemini/config/history/
_sys/gemini/config/installation_id
_sys/gemini/config/oauth_creds.json
_sys/gemini/config/projects.json
_sys/gemini/config/settings.json
_sys/gemini/config/state.json
_sys/gemini/config/trustedFolders.json
_sys/gemini/config/tmp/

# Deprecated: ratio/collab settings moved to _sys/ai/config.json
_sys/gemini/config.json

# Old version archives (moved to _sys/docs/Remains — not tracked)
_sys/docs/Remains

# =================================================================
# 6. Test Environments & Results
# =================================================================
_sys/tests/results/
_sys/tests/local_test_tmp/
_sys/tests/integration/parallel_test_tmp/
_sys/tests/integration/recovery_test_tmp/
_sys/tests/integration/local_test_tmp/
.pytest_cache/
setup_test_env.py

# =================================================================
# 7. Root-level session/debug log dumps
# =================================================================
/agy_log*.txt
/out.txt
/err.txt
/integration_log.txt
/integration_log*.txt

# =================================================================
# 8. System, Editor, & Cache Garbage
# =================================================================
.DS_Store
Thumbs.db
.vscode/
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
*.log
*.tmp
*.bak
