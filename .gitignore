# Porta-Flow: Minimal Core Git Ignore

# 1. Huge Binary Environments (Managed by install.bat)
_sys/env/**
!_sys/env/vscode/
!_sys/env/vscode/data/
!_sys/env/vscode/data/user-data/
!_sys/env/vscode/data/user-data/User/
!_sys/env/vscode/data/user-data/User/settings.json
!_sys/env/vscode/data/user-data/User/keybindings.json
_sys/tools/
_sys/data/temp/
_sys/data/setup-files/

# 2. User Data & Workspaces (Mandatory Exclusion)
workspace/
_workspace/
_archive/

# 3. Project-local AI State (.ai/ - ephemeral IPC)
.ai/
_state/

# Work Logs (ephemeral — archived in _archive/)
WORKLOG.md

# 4. Claude/Gemini Private State, Config & History (Dynamic)
_sys/claude/config/
!_sys/claude/config/CLAUDE.md
!_sys/claude/config/settings.json
!_sys/claude/config/statusline-command.sh
_sys/gemini/status.json
_sys/gemini/usage.json
_sys/gemini/session-id.txt
_sys/gemini/session-map.json
_sys/gemini/session.lock
_sys/gemini/config/
!_sys/gemini/config.json

# 5. Local Configs & Secrets
**/local.config.bat
.env
*.log

# 6. OS & IDE
.DS_Store
Thumbs.db
.vscode/
node_modules/
__pycache__/
*.pyc

# 7. Test Results
_sys/tests/results/
_sys/tests/local_test_tmp/
_sys/tests/integration/parallel_test_tmp/
_sys/tests/integration/recovery_test_tmp/
.pytest_cache/
