# Porta-Flow: Portable Sandbox Dev Environment - System Only Exclusions

# 1. Huge Binary Environments
_sys/env/
_sys/tools/
_sys/data/temp/
_sys/data/setup-files/

# 2. User Data & Workspaces (MANDATORY EXCLUSION)
workspace/
_workspace/
_archive/

# 3. Claude/Gemini Private State & History
_sys/claude/config/.credentials.json
_sys/claude/config/.claude.json
_sys/claude/config/.last-cleanup
_sys/claude/config/.last-update-result.json
_sys/claude/config/backups/
_sys/claude/config/cache/
_sys/claude/config/file-history/
_sys/claude/config/paste-cache/
_sys/claude/config/plans/
_sys/claude/config/projects/
_sys/claude/config/session-env/
_sys/claude/config/sessions/
_sys/claude/config/shell-snapshots/
_sys/claude/config/stats-cache.json
_sys/claude/config/tasks/
_sys/claude/config/teams/
_sys/claude/config/history.jsonl
_sys/gemini/config/
_sys/gemini/status.json

# 4. Plugin Cache & PC-Specific State
# (auto-regenerated by Claude Code on each install; contain hardcoded local paths)
_sys/claude/config/plugins/cache/
_sys/claude/config/plugins/plugin-catalog-cache.json
_sys/claude/config/plugins/known_marketplaces.json
_sys/claude/config/plugins/installed_plugins.json

# 5. Claude Code Daemon & Job Runtime
_sys/claude/config/daemon/
_sys/claude/config/daemon.lock
_sys/claude/config/daemon.status.json
_sys/claude/config/jobs/

# 6. Local Configs & Secrets
**/settings.local.json
**/local.config.bat
.env
*.log

# 7. OS & IDE
.DS_Store
Thumbs.db
.vscode/
node_modules/
__pycache__/
*.pyc

# 8. Test Runtime Output (results persist in results/ dir which IS tracked structure)
_sys/test/results/*.txt
_sys/test/results/*.json
